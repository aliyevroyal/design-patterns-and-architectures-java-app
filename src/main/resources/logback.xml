<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="FILE" value="var/logs/tagly-backend/api.log"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss} %highlight(%-5level) %magenta(${PID}) ${hostName} --- [%thread] %cyan(%logger{36}): %msg%n
            </pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${FILE}</file>
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss} %-5level ${PID} ${hostName} --- [%thread] %logger{36}: %msg%n
            </pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${FILE}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
    <logger name="org.springframework.web" level="INFO"/>
</configuration>
